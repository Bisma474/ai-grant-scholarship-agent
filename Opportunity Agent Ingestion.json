        "jsCode": "const profile = $('Get Profile').item.json;\nconst opp = $input.item.json;\n\nconst prompt = `You are an application assistant. Based on the student's profile, resume, and this opportunity, generate a short actionable checklist: required documents, an internal deadline pacing plan, and any gaps between the resume and the opportunity's stated requirements. Respond ONLY with valid JSON, no markdown, no preamble.\n\nSTUDENT PROFILE:\nField: ${profile.field}\nSkills: ${profile.skill}\nResume Summary: ${profile['resume-text']}\n\nOPPORTUNITY:\nTitle: ${opp.title}\nOrg: ${opp.org}\nDescription: ${opp.description}\nDeadline info if mentioned in description: extract it if present\n\nRespond in this exact JSON shape and nothing else:\n{\"checklist\": \"- Document 1\\\\n- Document 2\\\\n- Pacing step 1\\\\n- Pacing step 2\", \"resume_gaps\": \"one to two sentences on any mismatch between resume and requirements\"}`;\n\nreturn {\n  ...opp,\n  requestBody: JSON.stringify({\n    model: \"llama-3.3-70b-versatile\",\n    messages: [\n      { role: \"user\", content: prompt }\n    ]\n  })\n};"
      },
