        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are an eligibility checker. Given the student profile and opportunity below, determine eligibility. Respond ONLY with valid JSON, no markdown, no preamble, no explanation outside the JSON.\\n\\nSTUDENT PROFILE:\\nField: {{ $('Get Profile').item.json.field }}\\nDegree Level: {{ $('Get Profile').item.json['degree-level'] }}\\nCGPA: {{ $('Get Profile').item.json.cgpa }}\\nCountry: {{ $('Get Profile').item.json.country }}\\nSkills: {{ $('Get Profile').item.json.skill }}\\n\\nOPPORTUNITY:\\nTitle: {{ $('Dedup Check').item.json.title }}\\nOrg: {{ $('Dedup Check').item.json.org }}\\nDescription: {{ $('Dedup Check').item.json.description }}\\n\\nRespond in this exact JSON shape and nothing else:\\n{\\\"eligible\\\": true, \\\"reason\\\": \\\"one sentence\\\", \\\"missing_requirements\\\": []}\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1392,
        -672
      ],
      "id": "5796cef4-6157-435b-8837-86728833283f",
      "name": "Check Eligibility",
      "credentials": {
        "httpBearerAuth": {
          "id": "HjoVGMgRvfeH3PV2",
          "name": "Bearer Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const responseText = $input.item.json.choices[0].message.content;\nconst cleaned = responseText.replace(/```json|```/g, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = { eligible: false, reason: 'parse_error', missing_requirements: [] };\n}\n\n// Extract deadline from description\nconst description = $('Dedup Check').item.json.description || '';\nlet deadline = '';\n\nconst patterns = [\n  /Deadline:\\s*([A-Za-z]+\\s+\\d{1,2},?\\s+\\d{4})/i,\n  /Deadline:\\s*(\\d{1,2}\\s+[A-Za-z]+,?\\s+\\d{4})/i,\n  /Application Deadline:\\s*([A-Za-z]+\\s+\\d{1,2},?\\s+\\d{4})/i,\n  /Application Deadline:\\s*(\\d{1,2}\\s+[A-Za-z]+,?\\s+\\d{4})/i,\n  /Deadline:\\s*(On Rolling Basis)/i,\n  /Deadline:\\s*(Ongoing)/i,\n];\n\nfor (const pattern of patterns) {\n  const match = description.match(pattern);\n  if (match) {\n    deadline = match[1].trim();\n    break;\n  }\n}\n\nreturn {\n  ...$('Dedup Check').item.json,\n  eligible: parsed.eligible,\n  eligibilityReason: parsed.reason,\n  missingRequirements: (parsed.missing_requirements || []).join(', '),\n  deadline: deadline\n};"
      },
